                data.selected = not data.selected
                if data.selected then
                    TweenService:Create(checkBox, TweenInfo.new(0.25, Enum.EasingStyle.Back), {BackgroundColor3 = C.textPurple, BackgroundTransparency = 0}):Play()
                    checkMark.Text = "✓"
                else
