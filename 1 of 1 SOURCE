local oldObserve
oldObserve = hookfunction(BrainrotCard.ObserveOneOfOne, function(record, callback)
    return oldObserve(record, function(originalValue)
        if SelectedIndexes[record.Index] then
            callback(true)
        else
            callback(originalValue)
        end
    end)
end)

local oldApply
oldApply = hookfunction(BrainrotCard.ApplyOneOfOne, function(gui, state, ...)
    local title = gui:FindFirstChild("Spacer")
    if title and title:FindFirstChild("Title") then
        local name = title.Title.Text
        if SelectedIndexes[name] then
            state = true
        end
    end
    return oldApply(gui, state, ...)
end)

local originalPopulate
originalPopulate = hookfunction(OverheadController.Populate, function(self, data)
    originalPopulate(self, data)
    if data.Overhead then
        local banner = data.Overhead:FindFirstChild("1OF1Banner")
        if banner then
            local displayName = data.Overhead:FindFirstChild("DisplayName")
            if displayName and displayName:IsA("TextLabel") then
                banner.Visible = SelectedIndexes[displayName.Text] or false
            end
        end
    end
end)

local function forceBanners()
    for _, instance in ipairs(Workspace:GetDescendants()) do
        if instance.Name == "1OF1Banner" and instance:IsA("GuiObject") then
            local parent = instance.Parent
            local displayName = parent and parent:FindFirstChild("DisplayName")
            if displayName and displayName:IsA("TextLabel") then
                instance.Visible = SelectedIndexes[displayName.Text] or false
            end
        end
    end
    
    for _, part in ipairs(Debris:GetChildren()) do
        if part:IsA("Part") and part.Name == "FastOverheadTemplate" then
            local overhead = part:FindFirstChild("AnimalOverhead")
            if overhead then
                local displayName = overhead:FindFirstChild("DisplayName")
                local banner = overhead:FindFirstChild("1OF1Banner")
                if displayName and banner and banner:IsA("GuiObject") then
                    banner.Visible = SelectedIndexes[displayName.Text] or false
                end
            end
        end
    end
end

task.spawn(function()
    while true do
        task.wait(2)
        forceBanners()
    end
end)

